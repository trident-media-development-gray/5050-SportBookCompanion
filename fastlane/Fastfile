default_platform(:ios)

BUNDLE_ID = "sport.diary.companion.iosapp"
XCARGS = [
  "CODE_SIGN_STYLE=Manual",
  "DEVELOPMENT_TEAM=#{ENV["TEAM_ID"]}",
  "CODE_SIGN_IDENTITY='iPhone Distribution'",
  "PROVISIONING_PROFILE_SPECIFIER='match AppStore #{BUNDLE_ID}'",
  "COMPILER_INDEX_STORE_ENABLE=NO"
].join(" ")

platform :ios do

  desc "Load App Store Connect API key from environment"
  lane :load_asc_api_key do
    require "base64"
    # Decode here instead of passing is_key_content_base64: with that flag set,
    # deliver decodes the key (runner.rb) but leaves the flag in the hash, and
    # the altool transporter (itunes_transporter.rb) decodes it AGAIN — writing
    # a garbage .p8 that altool rejects with NSCocoaError 259 (fastlane 2.236.0).
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: Base64.decode64(ENV["ASC_KEY_CONTENT"]),
      in_house: false
    )
  end

  desc "Sync certificates and provisioning profiles via match"
  lane :sync_certificates do
    api_key = load_asc_api_key
    match(
      type: "appstore",
      app_identifier: BUNDLE_ID,
      api_key: api_key,
      team_id: ENV["TEAM_ID"],
      git_url: ENV["MATCH_GIT_URL"],
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"],
      keychain_name: ENV["MATCH_KEYCHAIN_NAME"],
      keychain_password: ENV["KEYCHAIN_PASSWORD"],
      readonly: is_ci
    )
  end

  desc "Revoke this account's iOS distribution certificates (each app has its own Apple account)"
  lane :revoke_distribution do
    load_asc_api_key
    require "spaceship"
    require "base64"
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key: Base64.decode64(ENV["ASC_KEY_CONTENT"])
    )
    certs = Spaceship::ConnectAPI::Certificate.all.select { |c| c.certificate_type.to_s.include?("DISTRIBUTION") }
    UI.message("Revoking #{certs.size} distribution certificate(s)…")
    certs.each do |c|
      begin
        c.delete!
        UI.success("Revoked #{c.id} (#{c.certificate_type})")
      rescue => e
        UI.error("Failed to revoke #{c.id}: #{e.message}")
      end
    end
  end

  desc "Increment build number based on latest TestFlight build"
  lane :bump_build_number do
    load_asc_api_key
    current = latest_testflight_build_number(
      app_identifier: BUNDLE_ID,
      initial_build_number: 0
    )
    increment_build_number(
      build_number: current + 1,
      xcodeproj: "iosApp/SportBookCompanion.xcodeproj"
    )
  end

  desc "Build + package the .ipa without uploading to App Store"
  lane :build_ipa do
    load_asc_api_key
    sync_certificates

    build_app(
      project: "iosApp/SportBookCompanion.xcodeproj",
      scheme: "SportBookCompanion",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "SportBookCompanion.ipa",
      xcargs: XCARGS
    )
  end

  desc "Build and upload to App Store"
  lane :release do
    load_asc_api_key
    sync_certificates
    bump_build_number

    build_app(
      project: "iosApp/SportBookCompanion.xcodeproj",
      scheme: "SportBookCompanion",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "SportBookCompanion.ipa",
      xcargs: XCARGS
    )

    upload_to_app_store(
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false
    )
  end
end
